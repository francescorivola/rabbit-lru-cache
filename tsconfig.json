{
    "include": ["./src/**/*.ts"],
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2020",
        "noImplicitAny": false,
        "declaration": true,
        "sourceMap": true,
        "rootDir": "src",
        "outDir": "build",
        "lib": ["es2020"],
        "noUnusedLocals": true,
        "strict": true
    }
}
